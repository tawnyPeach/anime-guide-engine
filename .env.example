# Database
# For local development without PostgreSQL (build succeeds but pages render on-demand):
# DATABASE_URL="postgresql://localhost:5432/anime_guide_dev"

# For local development with a running PostgreSQL:
DATABASE_URL="postgresql://localhost:5432/anime_guide_dev"

# For production (PostgreSQL/Neon):
# DATABASE_URL="postgresql://user:password@ep-example.us-east-2.aws.neon.tech/dbname?sslmode=require"

# Legacy SQLite format (requires changing schema.prisma provider to "sqlite"):
# DATABASE_URL="file:./dev.db"

# Site
NEXT_PUBLIC_SITE_URL="https://your-domain.com"
NEXT_PUBLIC_SITE_NAME="Anime Guide Engine"

# AdSense (optional - leave empty for development)
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""

# Cron Secret (required for /api/cron/sync endpoint authentication)
# Generate a random string: openssl rand -base64 32
CRON_SECRET=""
